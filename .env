# Configuración del servidor
PORT=8080
NODE_ENV=development
API_VERSION=v1
BASE_URL=http://localhost:8080

# Configuración de base de datos
DB_TYPE=mongodb
DB_HOST=localhost
DB_PORT=27017
DB_NAME=carai_events
DB_USER=root
DB_PASSWORD=password
MONGODB_URI=mongodb://localhost:27017/carai_events

# Configuración de autenticación
JWT_SECRET=your_super_strong_secret_key_change_this_in_production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Configuración de servicio de correo
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=user@example.com
MAIL_PASSWORD=your_mail_password
MAIL_FROM=noreply@caraiapp.com

# Configuración de almacenamiento de archivos
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880 # 5MB

# Configuración de logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Configuración de CORS
CORS_ORIGIN=*
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE

# Configuración de Redis (para caché/colas)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Configuración de AWS (si es necesario)
AWS_REGION=us-east-1
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
S3_BUCKET=carai-events-uploads

# Configuración de monitoreo
SENTRY_DSN=

# Configuración específica de eventos
EVENT_PROCESSING_QUEUE=events_queue
EVENT_CACHE_TTL=3600
MAX_EVENTS_PER_REQUEST=100